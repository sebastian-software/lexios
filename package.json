{
  "name": "lexios",
  "version": "0.3.0",
  "description": "Zod-first Brand ID schema, YAML exchange layer, and agent-facing Markdown export.",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./brand-id": {
      "types": "./dist/brand-id.d.ts",
      "import": "./dist/brand-id.js"
    },
    "./schema": {
      "types": "./dist/brand-id.schema.d.ts",
      "import": "./dist/brand-id.schema.js"
    },
    "./yaml": {
      "types": "./dist/brand-id.yaml.d.ts",
      "import": "./dist/brand-id.yaml.js"
    },
    "./markdown": {
      "types": "./dist/brand-id.markdown.d.ts",
      "import": "./dist/brand-id.markdown.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "demo:brand-report:build": "vite build examples/react-brand-report",
    "test:react-report": "npm run build && node scripts/smoke-react-report.mjs",
    "clean": "node --eval \"require('node:fs').rmSync('dist', { recursive: true, force: true })\""
  },
  "keywords": [
    "brand",
    "branding",
    "content-design",
    "schema",
    "typescript"
  ],
  "license": "UNLICENSED",
  "dependencies": {
    "yaml": "^2.0.0",
    "zod": "^4.0.0"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "typescript": "^5.0.0",
    "vite": "^8.0.8"
  }
}
